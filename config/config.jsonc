{
    // ==========================================
    //  CNN-Containers Configuration
    // ==========================================
    //
    // enabled       - set to false to remove a container from the game entirely
    // price         - trader price (roubles, dollars, or euros depending on the trader)
    // loyaltyLevel  - trader loyalty level required to buy (1-4)
    // gridH / gridV - internal grid size (columns x rows)
    //
    // Some optional settings are commented out (//) below each container and will revert to their default values.
    // To use one, just remove the // at the start of the line and edit the value.
    //
    // Use https://db.sp-tarkov.com/ to search for items to add to container extraFilters or extraExcludedFilters.
    // The "_id":string or "parentId":string values are used depending on whether you want to allow/ban a specific item or an entire category of items.
    //
    // fleaPrice             - flea market price in roubles (0 or commented out = use default handbook price)
    // extraFilters          - extra allowed item category or item IDs - can add multiple IDs followed by a comma, or just one ID in the array.
    //                         (e.g. for mods like Pack 'n' Strap - the parent item ID "6815465859b8c6ff13f94026" is added to the Gear Box's extraFilters)
    // extraExcludedFilters  - item IDs or parent category IDs to DISALLOW. Useful for the wooden box (which accepts everything by default)
    //                         to block specific items like the junk box, items case, weapons case, gear box, etc.
    // name                  - override the container's display name
    // shortName             - override the short name shown in inventory
    // description           - override the description text
    //
    // WARNING: Disabling a container or changing its grid size after you've stored items
    // inside it can cause profile corruption or item loss.
    // Always empty a container first before changing these settings.
    


    // --- Gear Box / Ragman (roubles) ---
    // Pre-loaded the extaFilters with the Pack 'n' Strap mod's parent item ID as it's quite a popular mod,
    // add any additional IDs using commas.
    "gearBox": {
        "enabled": true,
        "price": 850000,
        "loyaltyLevel": 3,
        "gridH": 10,
        "gridV": 8,
        //"fleaPrice": 0,
        "extraFilters": ["6815465859b8c6ff13f94026"],
        //"name": "Gear Box",
        //"shortName": "G-BOX",
        //"description": "A gear storage box.",
    },

